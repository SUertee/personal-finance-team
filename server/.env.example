# LLM Provider: "ollama" (default) or "openai"
LLM_PROVIDER=ollama

# Ollama settings (when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI settings (when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Intent Router (lightweight model for routing - defaults to main LLM keys if not set)
ROUTER_MODEL=openai/gpt-4o-mini
# ROUTER_API_KEY=sk-your-key-here
# ROUTER_BASE_URL=https://openrouter.ai/api/v1

# NewsAPI (https://newsapi.org - free tier available)
NEWS_API_KEY=your-news-api-key-here

# PostgreSQL (optional - falls back to in-memory if not set)
POSTGRES_DSN=postgresql://personal_finance_user:personal_finance_password@localhost:15432/personal_finance
